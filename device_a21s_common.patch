diff --git a/common.mk b/common.mk
index 76b9f18..5e014e2 100644
--- a/common.mk
+++ b/common.mk
@@ -38,6 +38,26 @@ PRODUCT_PACKAGES += \
     audio.usb.default \
     audio.primary.universal3830
 
+# IMS over Wi-Fi data service and network qualification service.
+# Required by the telephony framework even for VoLTE-only (no VoWiFi):
+# without these, DataServiceManager and NetworkRegistrationManager fail
+# to bind their WLAN handlers, which can cascade to IMS setup failures.
+PRODUCT_PACKAGES += \
+    Iwlan \
+    QualifiedNetworksService
+
+# IMS carrier overrides
+PRODUCT_PROPERTY_OVERRIDES += \
+    persist.dbg.volte_avail_ovr=1 \
+    persist.dbg.wfc_avail_ovr=1 \
+    persist.dbg.allow_ims_off=1
+
+PRODUCT_PACKAGES += \
+    PhhIms
+
+PRODUCT_COPY_FILES += \
+    $(COMMON_PATH)/privapp-permissions-me.phh.ims.xml:$(TARGET_COPY_OUT_SYSTEM)/etc/permissions/privapp-permissions-me.phh.ims.xml
+
 # Mixer
 PRODUCT_COPY_FILES += \
     $(COMMON_PATH)/configs/mixer/mixer_paths.xml:$(TARGET_COPY_OUT_VENDOR)/etc/mixer_paths.xml
@@ -254,6 +274,7 @@ PRODUCT_PACKAGES += \
     sehradiomanager \
     cbd
 
+
 PRODUCT_COPY_FILES += \
     $(COMMON_PATH)/configs/ril/sehradiomanager.conf:$(TARGET_COPY_OUT_VENDOR)/etc/sehradiomanager.conf
 
